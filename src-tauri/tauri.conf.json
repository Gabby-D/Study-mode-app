{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Study Mode",
  "version": "0.1.0",
  "identifier": "com.studymode.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Study Mode",
        "width": 680,
        "height": 640,
        "resizable": false,
        "minWidth": 680,
        "minHeight": 640
      },
      {
        "label": "clock",
        "title": "Focus Timer",
        "url": "clock.html",
        "width": 360,
        "height": 430,
        "minWidth": 300,
        "minHeight": 340,
        "resizable": true,
        "alwaysOnTop": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
